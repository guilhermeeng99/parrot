# Node / Bun (frontend)
node_modules/
dist/
build/
.svelte-kit/
*.tsbuildinfo
bun.lockb.*

# Rust / Tauri (frontend/src-tauri)
target/
**/target/

# Tauri externalBin sidecar binaries (the bundled uv.exe is ~67MB and host/
# version specific — devs place it per README "Build from source"; not committed).
frontend/src-tauri/binaries/

# Python (sidecar)
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/

# Parrot user data (voices, generated audio, DB, settings) — never committed
parrot_data/

# Editors / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# Playwright e2e artifacts (browsers live in a global cache, not the repo)
test-results/
playwright-report/
blob-report/
**/.last-run.json

# Claude Code session/workflow artifacts
.claude/

# Env
.env
.env.*
!.env.example
