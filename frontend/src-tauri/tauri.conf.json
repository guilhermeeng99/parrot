{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parrot",
  "version": "0.0.1",
  "identifier": "com.guilhermeeng99.parrot",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:3901",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Parrot",
        "width": 1000,
        "height": 700,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/uv"],
    "resources": {
      "../../sidecar/app": "sidecar/app",
      "../../sidecar/alembic": "sidecar/alembic",
      "../../sidecar/main.py": "sidecar/main.py",
      "../../sidecar/alembic.ini": "sidecar/alembic.ini",
      "../../sidecar/pyproject.toml": "sidecar/pyproject.toml",
      "../../sidecar/uv.lock": "sidecar/uv.lock",
      "../../README.md": "README.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/guilhermeeng99/Parrot/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_REGENERATE_BEFORE_RELEASE",
      "windows": { "installMode": "passive" }
    }
  }
}
